import matplotlib.pyplot as plt
import numpy as np
overs=np.arange(1,11)
scores=[10,11,6,7,14,19,18,3,9,14]
plt.bar(overs,scores)
plt.title("INDIA Score Over Wise")
plt.xlabel("Overs From 1 to 10 ")
plt.ylabel("Runs based on overs")
plt.xticks(overs)
plt.grid(axis='y',linestyle='--',alpha=0.7,color='Yellow')
plt.show()
